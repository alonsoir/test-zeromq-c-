[272.404237, "o", "\u001b[0;31m    defender: Note: switching to 'fdf402b384cc42ce29bb9e27011633be3cbafe1e'.\u001b[0m\r\n"]
[272.404357, "o", "\u001b[0;31m    defender: \u001b[0m\r\n"]
[272.404449, "o", "\u001b[0;31m    defender: You are in 'detached HEAD' state. You can look around, make experimental\u001b[0m\r\n"]
[272.404884, "o", "\u001b[0;31m    defender: changes and commit them, and you can discard any commits you make in this\u001b[0m\r\n"]
[272.404977, "o", "\u001b[0;31m    defender: state without impacting any branches by switching back to a branch.\u001b[0m\r\n"]
[272.405059, "o", "\u001b[0;31m    defender: \u001b[0m\r\n"]
[272.405145, "o", "\u001b[0;31m    defender: If you want to create a new branch to retain commits you create, you may\u001b[0m\r\n"]
[272.405229, "o", "\u001b[0;31m    defender: do so (now or later) by using -c with the switch command. Example:\u001b[0m\r\n"]
[272.405302, "o", "\u001b[0;31m    defender: \u001b[0m\r\n"]
