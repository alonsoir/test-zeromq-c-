# ML Defender — firewall-acl-agent
# Install: sudo install -m 0644 ml-defender-firewall-acl-agent.service /etc/systemd/system/
#          sudo systemctl daemon-reload && sudo systemctl enable ml-defender-firewall-acl-agent

[Unit]
Description=ML Defender — firewall-acl-agent (iptables/ipset enforcement)
Documentation=https://github.com/alonsoir/argus
After=network.target ml-defender-etcd-server.service ml-defender-sniffer.service
Requires=ml-defender-etcd-server.service

[Service]
Type=simple
User=root
Group=root

WorkingDirectory=/vagrant/firewall-acl-agent/build-active

EnvironmentFile=/etc/ml-defender/build.env
Environment="LD_PRELOAD="
Environment="PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
Environment="LD_LIBRARY_PATH=/usr/local/lib"

ExecStart=/vagrant/firewall-acl-agent/build-active/firewall-acl-agent -c ../config/firewall.json

Restart=always
RestartSec=5s
StartLimitInterval=300
StartLimitBurst=10

TimeoutStartSec=30s
TimeoutStopSec=15s

# Capabilities mínimas para iptables/ipset
AmbientCapabilities=CAP_NET_ADMIN CAP_NET_RAW
CapabilityBoundingSet=CAP_NET_ADMIN CAP_NET_RAW

StandardOutput=journal
StandardError=journal
SyslogIdentifier=ml-defender-firewall-acl-agent

KillMode=mixed
KillSignal=SIGTERM

[Install]
WantedBy=multi-user.target
