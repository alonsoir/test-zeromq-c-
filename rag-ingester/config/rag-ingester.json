{
  "service": {
    "id": "rag-ingester-default",
    "location": "default",
    "version": "0.1.0",

    "etcd": {
      "endpoints": ["127.0.0.1:2379"],
      "heartbeat_interval_sec": 10,
      "partner_detector": "ml-detector-default"
    }
  },

  "identity": {
    "_comment": "ADR-013 — provision.sh es el único responsable de crear estas claves.",
    "_phase": "PHASE 1: seed.bin en claro (chmod 0600). PHASE 2: seed.enc via seed-client.",
    "component_id": "rag-ingester",
    "keys_dir":     "/etc/ml-defender/rag-ingester",
    "public_key":   "/etc/ml-defender/rag-ingester/public.pem",
    "private_key":  "/etc/ml-defender/rag-ingester/private.pem",
    "seed_bin":     "/etc/ml-defender/rag-ingester/seed.bin"
  },

  "ingester": {
    "input": {
      "source": "file_watch",
      "directory": "/vagrant/logs/rag/empty",
      "pattern": "*.pb.enc",
      "encrypted": true,
      "compressed": true,
      "delete_after_process": false,

      "csv_ml_detector_dir":          "/vagrant/logs/ml-detector/events/",
      "csv_ml_detector_hmac_key_hex": "",

      "csv_firewall_path":            "/vagrant/logs/firewall_logs/firewall_blocks.csv",
      "csv_firewall_hmac_key_hex":    "",
      "replay_on_start":              true
    },

    "threading": {
      "mode": "single",
      "embedding_workers": 1,
      "indexing_workers": 1
    },

    "embedders": {
      "chronos": {
        "enabled": true,
        "onnx_path": "/vagrant/rag-ingester/models/onnx/chronos.onnx",
        "input_dim": 83,
        "output_dim": 512
      },
      "sbert": {
        "enabled": true,
        "onnx_path": "/vagrant/rag-ingester/models/onnx/sbert.onnx",
        "input_dim": 83,
        "output_dim": 384
      },
      "attack": {
        "enabled": true,
        "onnx_path": "/vagrant/rag-ingester/models/onnx/attack.onnx",
        "input_dim": 83,
        "output_dim": 256,
        "benign_sample_rate": 0.1
      }
    },

    "pca": {
      "enabled": true,
      "chronos_model": "/vagrant/rag-ingester/models/pca/chronos_512_128.faiss",
      "sbert_model": "/vagrant/rag-ingester/models/pca/sbert_384_96.faiss",
      "attack_model": "/vagrant/rag-ingester/models/pca/attack_256_64.faiss"
    },

    "faiss": {
      "index_type": "Flat",
      "metric": "L2",
      "persist_path": "/shared/faiss_indexes",
      "checkpoint_interval_events": 1000
    },

    "health": {
      "cv_warning_threshold": 0.20,
      "cv_critical_threshold": 0.15,
      "report_to_etcd": true
    }
  },
  "plugins": {
    "enabled": [
      {
        "name": "hello",
        "path": "/usr/lib/ml-defender/plugins/libplugin_hello.so",
        "active": true,
        "comment": "ADR-012 PHASE 1b — validation plugin"
      }
    ]
  }
}