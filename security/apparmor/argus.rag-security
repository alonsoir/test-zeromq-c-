#include <tunables/global>
# /etc/apparmor.d/argus.rag-security
# AppArmor profile para aRGus rag-security (TinyLlama local).
# Sin capabilities especiales. Solo lectura de FAISS index + query HTTP.
# TinyLlama deliberadamente local — sin llamadas a cloud LLMs.
#
# DAY 133 — aRGus NDR — ADR-030 Variant A

profile argus-rag-security /opt/argus/bin/rag-security {
  #include <abstractions/base>

  capability ipc_lock,

  network inet tcp,
  network inet6 tcp,

  /opt/argus/bin/rag-security   mr,
  /opt/argus/bin/rag-security.sig r,

  /opt/argus/lib/**            mr,
  /usr/local/lib/libsodium.so*    mr,
  /usr/local/lib/libzmq.so*       mr,
  /usr/local/lib/libfaiss.so*     mr,
  /usr/local/lib/libonnxruntime.so* mr,
  /usr/local/lib/libcrypto_transport.so* mr,
  /usr/local/lib/libseed_client.so*      mr,
  /usr/local/lib/libplugin_loader.so*    mr,
  /usr/local/lib/libetcd_client.so*      mr,
  /lib/x86_64-linux-gnu/**     mr,
  /usr/lib/x86_64-linux-gnu/** mr,

  /opt/argus/models/tinyllama*.gguf r,
  /opt/argus/models/**              r,

  /etc/ml-defender/rag-security/** r,
  /etc/ml-defender/plugins/plugin_signing.pk r,
  /opt/argus/plugins/*.so  mr,
  /opt/argus/plugins/*.sig r,

  /var/log/argus/rag-security/  rw,
  /var/log/argus/rag-security/** rw,

  /proc/@{pid}/status r,
  /proc/cpuinfo r,

  deny /root/**    rwx,
  deny /home/**    rwx,
  deny /tmp/**     x,
  deny /var/tmp/** x,
  deny /etc/passwd w,
  deny /etc/shadow rw,
  deny /sys/fs/bpf/** rwx,
  deny /etc/ml-defender/firewall-acl-agent/** rwx,
  deny /opt/argus/bin/firewall-acl-agent x,
  deny /sbin/iptables x,
  deny /sbin/ipset    x,

  # ── APT Sources integrity (DEBT-PROD-APT-SOURCES-INTEGRITY-001 DAY 135) ───
  deny /etc/apt/sources.list w,
  deny /etc/apt/sources.list.d/** w,
  deny /etc/apt/trusted.gpg.d/** w,
  deny /etc/apt/preferences.d/** w,
}
