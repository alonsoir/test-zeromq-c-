#include <tunables/global>

/vagrant/rag-ingester/build-active/rag-ingester flags=(complain) {
  #include <abstractions/base>
  #include <abstractions/nameservice>

  /vagrant/rag-ingester/build-*/rag-ingester r,
  /usr/local/lib/libcrypto_transport.so mr,
  /usr/local/lib/libseed_client.so mr,
  /usr/local/lib/libplugin_loader.so mr,
  /usr/lib/** mr,
  /lib/** mr,

  /etc/ml-defender/rag-ingester/ r,
  /etc/ml-defender/rag-ingester/** r,

  /vagrant/logs/lab/rag-ingester.log w,
  /vagrant/logs/lab/ rw,
  /vagrant/shared/ rw,
  /vagrant/shared/** rw,

  # Provision --reset paths
  /etc/ml-defender/rag-ingester.bak.*/ rw,
  /etc/ml-defender/rag-ingester.bak.*/** rw,

  network tcp,
  network unix,

  /proc/self/** r,

  deny /usr/bin/ml-defender-* w,
}
