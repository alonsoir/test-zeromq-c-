#include <tunables/global>

/vagrant/rag/build-active/rag-security flags=(complain) {
  #include <abstractions/base>
  #include <abstractions/nameservice>

  /vagrant/rag/build-active/rag-security r,
  /usr/local/lib/libcrypto_transport.so mr,
  /usr/local/lib/libseed_client.so mr,
  /usr/lib/** mr,
  /lib/** mr,

  /etc/ml-defender/rag-security/ r,
  /etc/ml-defender/rag-security/** r,

  /vagrant/logs/lab/rag-security.log w,
  /vagrant/logs/lab/ rw,
  /vagrant/shared/ rw,
  /vagrant/shared/** rw,

  # Provision --reset paths
  /etc/ml-defender/rag-security.bak.*/ rw,
  /etc/ml-defender/rag-security.bak.*/** rw,

  network tcp,
  network unix,

  /proc/self/** r,

  deny /usr/bin/ml-defender-* w,
}
