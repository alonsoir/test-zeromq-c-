{
  "_comment": "argus-network-isolate config \u2014 ADR-042 IRP",
  "_version": "1.0.0",
  "nft_path": "/usr/sbin/nft",
  "backup_dir": "/tmp",
  "rollback_timeout_sec": 300,
  "table_name": "argus_isolate",
  "whitelist_ips": [
    "127.0.0.1",
    "10.0.2.2",
    "10.0.2.15",
    "192.168.56.1"
  ],
  "whitelist_ports": [
    22
  ],
  "log_path": "/var/log/argus/network-isolate.log",
  "forensic_log_path": "/var/log/argus/network-isolate-forensic.jsonl",
  "auto_isolate": true,
  "threat_score_threshold": 0.95,
  "auto_isolate_event_types": [
    "ransomware",
    "lateral_movement",
    "c2_beacon"
  ],
  "isolate_interface": "eth1"
}
